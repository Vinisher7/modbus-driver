# ── Postgres (aplicação + docker-compose) ─────────────────────
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_SERVER=""
POSTGRES_PORT=""
POSTGRES_DB=""

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER="tcp://emqx:1883"
MQTT_CLIENT_ID="mqtt-driver"
MQTT_USERNAME=""
MQTT_PASSWORD=""

# ── Driver ────────────────────────────────────────────────────
POLL_INTERVAL="10s"
MODBUS_TIMEOUT="10s"
DEVICE_GROUP_SIZE="5"

# ── Makefile (migrations locais — NÃO usado pela aplicação) ──
# Formato: postgres://user:password@host:port/dbname?sslmode=disable
MAKEFILE_DB_STRING="postgres://user:password@localhost:5433/dbname?sslmode=disable"
MAKEFILE_DIR="internal/database/migrations"

# ── Tenant CODE para envio ────────────────────────────────────────────────────
TENANT_CODE="example"